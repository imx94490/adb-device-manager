{
  "name": "adb-device-manager",
  "version": "1.0.0",
  "description": "ADB Device Manager - A modern desktop tool for managing Android devices",
  "main": "dist/main/main/index.js",
  "author": "ADB Device Manager",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "dev:all": "concurrently -k \"npm run dev\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "build": "tsc -p tsconfig.main.json && vite build",
    "build:vite": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "dist": "npm run build && electron-builder",
    "dist:portable": "npm run build && electron-builder --win portable",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.2",
    "lucide-react": "^0.441.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.1.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.adbmanager.dev",
    "productName": "ADB Device Manager",
    "asar": false,
    "directories": {
      "output": "release-output"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": ["x64"]
        }
      ],
      "icon": "public/icon.png"
    }
  }
}
